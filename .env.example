# ============================================================
# COHORTS — Environment Variables
# Copy this file to .env and fill in your Supabase credentials
# ============================================================

# Get these from: https://supabase.com/dashboard → your project → Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key-here

# Without these, the app falls back to siteConfig.js static data (still works fine)
